[Unit]
Description=NGN6 paper-trading dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/ngn6-bot
EnvironmentFile=/opt/ngn6-bot/.env
ExecStart=/opt/ngn6-bot/.venv/bin/ngn6-bot dashboard --config /opt/ngn6-bot/config/ngn6.yaml --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30
User=ngn6bot
Group=ngn6bot

[Install]
WantedBy=multi-user.target
