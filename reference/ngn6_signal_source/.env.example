PORT=3002
DASHBOARD_HOST_PORT=3002
MARKET_RANGE=12mo
MARKET_RANGE_INTRADAY=60d
MARKET_INTERVAL_INTRADAY=15m

# T-Bank Invest API token.
TBANK_API_TOKEN=

# Alternative token file path.
# TBANK_TOKEN_FILE=C:\Users\HONOR\Desktop\жрт новый про.txt

# Default NGN6 natural gas contract in T-Bank.
# TBANK_GAS_INSTRUMENT_ID=ddd7405e-f3df-4c29-a876-e865013c4e54
# TBANK_GAS_TICKER=NGN6
# TBANK_GAS_NAME=NG-7.26 Природный газ
# TBANK_GAS_SEARCH=NGN6,NG-7.26,Природный газ,Natural Gas,Henry Hub
# TBANK_REST_URLS=https://invest-public-api.tbank.ru/rest
# On Windows scripts auto-use certs/russiantrustedca.pem as NODE_EXTRA_CA_CERTS before Node starts.

# News refresh and analysis.
# NEWS_CACHE_MS=60000
# NEWS_LOOKBACK_HOURS=72
# NEWS_MAX_ITEMS=10
# NEWS_RSS_URLS=https://www.naturalgasintel.com/feed/,https://www.eia.gov/rss/todayinenergy.xml,https://www.investing.com/rss/commodities.rss,https://oilprice.com/rss/main

# Market and calendar cache.
# SNAPSHOT_CACHE_MS=60000
# CALENDAR_CACHE_MS=21600000

# Signal watcher.
SIGNAL_DELIVERY_MODE=daily-plan
# SIGNAL_TIMEFRAMES=daily
# SIGNAL_WATCH_INTERVAL_MS=60000
# SIGNAL_DAILY_PLAN_TIME=10:20
# SIGNAL_DAILY_PLAN_WINDOW_MINUTES=20
# SIGNAL_DAILY_PLAN_WEEKDAYS_ONLY=true
# SIGNAL_INTRADAY_RECHECK_TIMES=09:05,09:30,10:00,10:30,15:00,17:45,20:30
# SIGNAL_INTRADAY_RECHECK_WINDOW_MINUTES=15
# SIGNAL_INTRADAY_RECHECK_TIMEFRAME=intraday
# SIGNAL_INTRADAY_MIN_PROBABILITY=53
# SIGNAL_INTRADAY_MIN_LEVEL_CHANGE_PCT=0.45
# SIGNAL_HYBRID_MORNING_MIN_PROBABILITY=53
# SIGNAL_MAX_TRADE_SIGNALS_PER_DAY=3
# SIGNAL_STATE_FILE=/app/data/signal-watcher-state.json
# SIGNAL_HOST_DATA_DIR=./data
# SIGNAL_EMERGENCY_NEWS_SCORE=0.85
# SIGNAL_EMERGENCY_NEWS_MAX_AGE_HOURS=6
# SIGNAL_EMERGENCY_PRICE_MOVE_PCT=1.8
# SIGNAL_CLOSE_NEWS_CONFIDENCE=0.65
# SIGNAL_ENTRY_WARNING_DISTANCE_PCT=0.3
# SIGNAL_TP_MANAGEMENT_ENABLED=true
# SIGNAL_TP1_STOP_LOCK_R=0.25
# SIGNAL_TP1_STOP_BUFFER_ATR=0.1
# SIGNAL_TP1_STOP_BUFFER_PCT=0.0015
# SIGNAL_IMPULSE_ENABLED=true
# SIGNAL_IMPULSE_SESSION_START=09:00
# SIGNAL_IMPULSE_MOVE_PCT=1.2
# SIGNAL_IMPULSE_BREAKOUT_BUFFER_PCT=0.03
# SIGNAL_IMPULSE_MIN_TREND=0.28
# SIGNAL_IMPULSE_MIN_MOMENTUM=0.24
# SIGNAL_IMPULSE_MIN_PROBABILITY=55.5
# SIGNAL_IMPULSE_MAX_PROBABILITY=63.5
# SIGNAL_HEARTBEAT_FILE=/app/data/signal-watcher-heartbeat.json
# SIGNAL_CYCLE_TIMEOUT_MS=180000
# SIGNAL_EXECUTION_STOP_BUFFER_ATR=0.1
# SIGNAL_EXECUTION_STOP_BUFFER_PCT=0.0015
# SIGNAL_EXECUTION_MIN_RISK_ATR=0.25
# SIGNAL_EXECUTION_MIN_RISK_PCT=0.004
# SIGNAL_EXECUTION_MAX_RISK_ATR=0.7
# SIGNAL_EXECUTION_MAX_RISK_PCT=0.018
# SIGNAL_EXECUTION_TP1_R=0.9
# SIGNAL_EXECUTION_TP2_R=1.55
#
# Legacy noisy mode, disabled by default:
# SIGNAL_NOTIFY_MODE=change
# SIGNAL_REPEAT_MS=1800000

# Paper trading. No real orders are sent; fills are virtual from the live order book.
# PAPER_TRADER_ENABLED=true
# PAPER_TRADER_INTERVAL_MS=60000
# PAPER_POSITION_CONTRACTS=1
# PAPER_POINT_VALUE=1
# PAPER_ORDERBOOK_DEPTH=20
# PAPER_TP1_FRACTION=0.5
# PAPER_CLOSE_ON_SIGNAL_FLIP=true
# PAPER_CLOSE_ON_NEUTRAL=false
# PAPER_NOTIFY_TRADES=true
# PAPER_STATE_FILE=/app/data/paper-trader-state.json
# PAPER_EVENT_DIR=/app/data/paper/events
# PAPER_ORDERBOOK_DIR=/app/data/paper/orderbook
# PAPER_HEARTBEAT_FILE=/app/data/paper-trader-heartbeat.json
# PAPER_CYCLE_TIMEOUT_MS=180000

# Watchdog restarts workers when heartbeat is older than this value.
# WATCHDOG_HEARTBEAT_MAX_AGE_MS=240000

# Telegram notifications.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# MAX notifications. Use MAX_USER_ID for a private chat or MAX_CHAT_ID for a group/chat.
# MAX_BOT_TOKEN=
# MAX_USER_ID=
# MAX_CHAT_ID=
# MAX_API_BASE_URL=https://platform-api2.max.ru

# ntfy push notifications. Easiest setup: install ntfy app and subscribe to NTFY_TOPIC.
# NTFY_TOPIC=ngn6-gas-secret-random-topic
# NTFY_SERVER=https://ntfy.sh
# NTFY_URL=
# NTFY_TITLE=NGN6 gas signal
# NTFY_PRIORITY=high
# NTFY_TAGS=chart_with_upwards_trend,gas
# NTFY_CLICK_URL=http://localhost:3002
# NTFY_RETRY_ATTEMPTS=5
# NTFY_TIMEOUT_MS=15000
# NTFY_AUTH_TOKEN=
# NTFY_USERNAME=
# NTFY_PASSWORD=

# Universal webhook.
# SIGNAL_WEBHOOK_URL=
